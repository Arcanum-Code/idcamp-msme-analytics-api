generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator prismabox {
  provider                    = "prismabox"
  typeboxImportDependencyName = "elysia"
  typeboxImportVariableName   = "t"
  inputModel                  = true
  output                      = "../generated/prismabox"
  binaryTargets               = ["native", "debian-openssl-3.0.x"]
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String
  name          String?
  isActive      Boolean        @default(true)
  tokenVersion  Int            @default(0)
  roleId        String
  role          Role           @relation(fields: [roleId], references: [id], onDelete: Restrict)
  refreshTokens RefreshToken[]
  shops         Shop[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Role {
  id          String        @id @default(cuid())
  name        String        @unique
  description String?
  users       User[]
  permissions RoleFeature[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Feature {
  id          String        @id @default(cuid())
  name        String        @unique
  description String?
  roles       RoleFeature[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RoleFeature {
  id String @id @default(cuid())

  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  featureId String
  feature   Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  canCreate Boolean @default(false)
  canRead   Boolean @default(false)
  canUpdate Boolean @default(false)
  canDelete Boolean @default(false)
  canPrint  Boolean @default(false)

  @@unique([roleId, featureId])
}

enum UploadStatus {
  UPLOADED
  DETECTING_COLUMNS
  NEEDS_MAPPING
  READY
  FAILED
}

enum ReportStatus {
  PROCESSING
  COMPLETED
  FAILED
}

enum PeriodType {
  DAILY
  WEEKLY
  MONTHLY
}

model Shop {
  id          String           @id @default(cuid())
  name        String           @db.VarChar(255)
  description String?          @db.Text
  ownerId     String
  owner       User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  uploads     RawUpload[]
  reports     ReportSnapshot[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([ownerId])
}

model RawUpload {
  id           String       @id @default(cuid())
  shopId       String
  shop         Shop         @relation(fields: [shopId], references: [id])
  filename     String
  filePath     String
  status       UploadStatus @default(UPLOADED)
  columnMap    Json?        // Record<string, string | null>
  unmappedRequired String[] @default([])
  rowCount     Int?
  error        Json?        // { code, message }
  uploadedAt   DateTime     @default(now())
  processedAt  DateTime?
  reports      ReportSnapshot[]

  @@index([shopId])
}

model ReportSnapshot {
  id           String       @id @default(cuid())
  shopId       String
  shop         Shop         @relation(fields: [shopId], references: [id])
  uploadId     String
  upload       RawUpload    @relation(fields: [uploadId], references: [id])
  periodType   PeriodType
  periodStart  DateTime     @db.Date
  periodEnd    DateTime     @db.Date
  status       ReportStatus @default(PROCESSING)
  revenueData  Json?        // result object from FastAPI
  narrative    String?
  error        Json?
  computedAt   DateTime?
  createdAt    DateTime     @default(now())

  @@unique([uploadId, periodType, periodStart, periodEnd])
  @@index([shopId])
}
